    def parse_rate_notice(self, payload: PagePayload) -> Dict[str, Any]:
        text = payload.native_text or payload.best_text
        lines = [clean_line(line) for line in text.splitlines() if clean_line(line)]
        rate_rows: List[Dict[str, Any]] = []
        row_re = re.compile(
            rf"^(?P<product>.+?)\s+Imp\. Gal\s+(?P<unit_price>{NUM_RE})\s+(?P<vat>{NUM_RE})\s+(?P<incl_vat>{NUM_RE})$",
            re.IGNORECASE,
        )
        for line in lines:
            m = row_re.match(line)
            if m:
                rate_rows.append({
                    "product": clean_line(m.group("product")),
                    "uom": "Imp. Gal",
                    "unit_price_aed": parse_number(m.group("unit_price")),
                    "vat_aed": parse_number(m.group("vat")),
                    "unit_price_incl_vat_aed": parse_number(m.group("incl_vat")),
                })
        return {
            "page_no": payload.page_no,
            "support_type": "RATE_NOTICE",
            "date": self.extract_multiline_field(text, [r"Date"]),
            "our_ref": self.extract_multiline_field(text, [r"Our Ref"]),
