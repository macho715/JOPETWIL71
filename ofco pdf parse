NUM_RE = r"(?:\d{1,3}(?:,\d{3})*|\d+)(?:\.\d+)?"
OCR_SCORE_KEYWORDS = [
    "tax invoice",
    "delivery note",
    "manifest",
    "shipping list",
    "cargo manifest",
    "subject",
    "from",
    "sent",
    "rotation",
    "ofco",
    "safeen",
    "abu dhabi ports",
    "invoice total",
    "invoice number",
    "diesel",
    "fresh water",
    "bunker",
    "permit",
    "adnoc",
]


@dataclass
class PagePayload:
    page_no: int
    native_text: str = ""
    ocr_text: str = ""
    best_text: str = ""
    text_source: str = "native"
    rotation: int = 0
    page_type: str = "IGNORE"
    confidence: float = 0.0
    parsed: Dict[str, Any] = field(default_factory=dict)


@dataclass
class DocumentResult:
    pdf_path: str
    page_count: int
    page_summary: List[Dict[str, Any]]
    master_header: Dict[str, Any]
