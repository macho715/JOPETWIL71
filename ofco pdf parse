    def slice_text(self, text: str, start_markers: Sequence[str], stop_markers: Sequence[str]) -> str:
        lower = text.lower()
        start_idx = 0
        for marker in start_markers:
            pos = lower.find(marker.lower())
            if pos >= 0:
                start_idx = pos
                break

        stop_idx = len(text)
        for marker in stop_markers:
            pos = lower.find(marker.lower(), start_idx + 1)
            if pos >= 0:
                stop_idx = min(stop_idx, pos)
        return text[start_idx:stop_idx]

    # ------------------------------------------------------------------ #
    # document orchestration
    # ------------------------------------------------------------------ #
    def parse_page(self, payload: PagePayload) -> Dict[str, Any]:
        payload.page_type, payload.confidence = self.classify_page(payload)

        if payload.page_type == "MASTER_OFCO":
            payload.parsed = self.parse_master_page(payload)
        elif payload.page_type == "VENDOR_SAFEEN":
            payload.parsed = self.parse_safeen_ocr_page(payload)
        elif payload.page_type == "VENDOR_ADP":
            payload.parsed = self.parse_adp_ocr_page(payload)
        elif payload.page_type in {"SUPPORT_MANIFEST", "SUPPORT_PACKING_LIST"}:
            payload.parsed = self.parse_manifest_support(payload)
        elif payload.page_type == "SUPPORT_DELIVERY_NOTE":
            payload.parsed = self.parse_delivery_note_support(payload)
        elif payload.page_type == "SUPPORT_EMAIL":
            payload.parsed = self.parse_email_support(payload)
        elif payload.page_type == "SUPPORT_RATE_NOTICE":
            payload.parsed = self.parse_rate_notice(payload)
        elif payload.page_type == "SUPPORT_PERMIT":
            payload.parsed = self.parse_permit_support(payload)
        else:
            payload.parsed = {"page_no": payload.page_no}

        return asdict(payload)

    def link_to_master(self, master_rows: List[Dict[str, Any]], vendor_docs: List[Dict[str, Any]], support_docs: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
        links: List[Dict[str, Any]] = []
        for row in master_rows:
            description = row.get("description", "") or ""
            row_refs = set(re.findall(r"(?:SAFEEN\s+INV-\d+|ADP\s+INV-\d+|ADP\s+INV\d+)", description, re.IGNORECASE))
            row_rotation = search_value(description, [r"Rot#\s*([0-9]{6,})"], flags=re.IGNORECASE)

            linked_vendor_pages = []
            for doc in vendor_docs:
                invoice_no = (doc.get("invoice_number") or "").strip()
                rotation_no = (doc.get("rotation_no") or "").strip()
                if invoice_no and any(invoice_no.lower() in ref.lower() for ref in row_refs):
                    linked_vendor_pages.append(doc.get("page_no"))
                    continue
                if row_rotation and rotation_no and row_rotation in rotation_no:
                    linked_vendor_pages.append(doc.get("page_no"))

            linked_support_pages = []
            for doc in support_docs:
                rotation_no = (doc.get("rotation_no") or "").strip()
                if row_rotation and rotation_no and row_rotation in rotation_no:
                    linked_support_pages.append(doc.get("page_no"))
                    continue
                subject = (doc.get("subject") or "").lower()
                if "fresh water" in description.lower() and "fresh water" in subject:
                    linked_support_pages.append(doc.get("page_no"))
                elif "mgo" in description.lower() and ("diesel" in subject or "fuel oil" in subject or doc.get("support_type") == "RATE_NOTICE"):
                    linked_support_pages.append(doc.get("page_no"))

            links.append({
                "master_sn": row.get("sn"),
                "master_description": description,
                "vendor_pages": sorted(set(p for p in linked_vendor_pages if p)),
                "support_pages": sorted(set(p for p in linked_support_pages if p)),
            })

        return links

    def parse_document(self) -> DocumentResult:
        page_results: List[Dict[str, Any]] = []
        master_header: Dict[str, Any] = {}
        master_rows: List[Dict[str, Any]] = []
        vendor_docs: List[Dict[str, Any]] = []
        support_docs: List[Dict[str, Any]] = []

        page_numbers = self.pages if self.pages else list(range(1, len(self.doc) + 1))
        for page_no in page_numbers:
            payload = self.extract_page_payload(page_no)
            result = self.parse_page(payload)
            page_results.append(result)

            page_type = result["page_type"]
            parsed = result["parsed"]

            if page_type == "MASTER_OFCO":
                if parsed.get("header"):
                    master_header.update(parsed["header"])
                if parsed.get("totals"):
                    master_header["grand_totals"] = parsed["totals"]
                if parsed.get("vat_anchor"):
                    master_header["vat_anchor"] = parsed["vat_anchor"]
                if parsed.get("bank_details"):
                    master_header["bank_details"] = parsed["bank_details"]
                if parsed.get("rows"):
                    master_rows.extend(parsed["rows"])
            elif page_type.startswith("VENDOR_"):
                vendor_docs.append(parsed)
            elif page_type.startswith("SUPPORT_"):
                support_docs.append(parsed)

        linkages = self.link_to_master(master_rows, vendor_docs, support_docs)

        page_summary = [
            {
                "page_no": row["page_no"],
                "page_type": row["page_type"],
                "confidence": row["confidence"],
                "text_source": row["text_source"],
                "rotation": row["rotation"],
            }
            for row in page_results
        ]

        return DocumentResult(
            pdf_path=str(self.pdf_path),
            page_count=len(self.doc),
            page_summary=page_summary,
            master_header=master_header,
            master_rows=master_rows,
            vendor_invoices=vendor_docs,
            support_documents=support_docs,
            linkages=linkages,
        )

    # ------------------------------------------------------------------ #
    # exports
    # ------------------------------------------------------------------ #
    def export(self, result: DocumentResult) -> None:
        self.out_dir.mkdir(parents=True, exist_ok=True)
        json_path = self.out_dir / "parsed_document.json"
        json_path.write_text(json.dumps(asdict(result), ensure_ascii=False, indent=2), encoding="utf-8")

        self.write_csv(self.out_dir / "page_summary.csv", result.page_summary)
        self.write_csv(self.out_dir / "master_rows.csv", result.master_rows)
        self.write_csv(self.out_dir / "vendor_invoices.csv", flatten_dict_rows(result.vendor_invoices))
        self.write_csv(self.out_dir / "support_documents.csv", flatten_dict_rows(result.support_documents))
        self.write_csv(self.out_dir / "linkages.csv", flatten_dict_rows(result.linkages))

    @staticmethod
    def write_csv(path: Path, rows: List[Dict[str, Any]]) -> None:
        if not rows:
            path.write_text("", encoding="utf-8")
            return

        fieldnames: List[str] = []
        seen = set()
        for row in rows:
            for key in row.keys():
                if key not in seen:
                    fieldnames.append(key)
                    seen.add(key)

        with path.open("w", encoding="utf-8-sig", newline="") as f:
            writer = csv.DictWriter(f, fieldnames=fieldnames)
            writer.writeheader()
            for row in rows:
                writer.writerow(row)



def parse_page_range(expr: Optional[str], max_page: Optional[int] = None) -> List[int]:
    if not expr:
        return []
    pages: List[int] = []
    for chunk in expr.split(","):
        chunk = chunk.strip()
        if not chunk:
            continue
        if "-" in chunk:
            a, b = chunk.split("-", 1)
            start, end = int(a), int(b)
            if start > end:
                start, end = end, start
            pages.extend(range(start, end + 1))
        else:
            pages.append(int(chunk))
    pages = sorted(set(pages))
    if max_page is not None:
        pages = [p for p in pages if 1 <= p <= max_page]
    return pages

def main() -> None:
    parser = argparse.ArgumentParser(description="OFCO monthly invoice PDF parser (local, ready to run).")
    parser.add_argument("pdf", type=Path, help="Input PDF path")
    parser.add_argument("--outdir", type=Path, default=Path("ofco_parse_out"), help="Output directory")
    parser.add_argument("--ocr-dpi", type=int, default=220, help="OCR raster DPI for scanned pages")
    parser.add_argument("--ocr-lang", type=str, default="eng", help="Tesseract language code(s), e.g. eng or eng+ara")
    parser.add_argument("--no-ocr", action="store_true", help="Disable OCR fallback")
    parser.add_argument("--pages", type=str, default="", help="Page subset, e.g. 1-3,40,44")
    args = parser.parse_args()

    page_subset = parse_page_range(args.pages)

    parser_obj = OFCOPdfParser(
        pdf_path=args.pdf,
        out_dir=args.outdir,
        ocr_dpi=args.ocr_dpi,
        ocr_lang=args.ocr_lang,
        enable_ocr=not args.no_ocr,
        pages=page_subset,
    )
    result = parser_obj.parse_document()
    parser_obj.export(result)

    print(f"Parsed: {args.pdf}")
    print(f"Pages: {result.page_count}")
    print(f"Master rows: {len(result.master_rows)}")
    print(f"Vendor docs: {len(result.vendor_invoices)}")
    print(f"Support docs: {len(result.support_documents)}")
    print(f"Saved to: {args.outdir}")


if __name__ == "__main__":
    main()
